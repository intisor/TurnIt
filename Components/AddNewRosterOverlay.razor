@if (IsVisible)
{
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/60 backdrop-blur-[2px] z-40" @onclick="Close"></div>

    <!-- Full-screen slide-over from right -->
    <div class="fixed inset-y-0 right-0 w-full sm:w-[85%] max-w-md bg-surface-bright z-50 flex flex-col slide-over-enter slide-over-active">
        <!-- Header -->
        <header class="flex items-center justify-between px-4 h-14 border-b border-outline-variant bg-surface-bright shrink-0"
                style="padding-top: env(safe-area-inset-top, 0px)">
            <button class="w-11 h-11 flex items-center justify-center rounded-full hover:bg-surface-variant active:bg-surface-container transition-colors"
                    @onclick="Close">
                <span class="material-symbols-outlined text-on-surface">close</span>
            </button>
            <h1 class="font-headline-sm text-headline-sm text-on-surface">New Roster</h1>
            <div class="w-11 h-11 rounded-2xl bg-roster-1/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-roster-1 text-[20px]" style="font-variation-settings: 'FILL' 1;">groups</span>
            </div>
        </header>

        <!-- Form body -->
        <div class="flex-1 overflow-y-auto px-4 py-5 space-y-4">
            <p class="text-on-surface-variant font-body-md">
                Create a rotation group. Add members afterwards from the Roster tab.
            </p>

            <!-- Roster Name -->
            <div>
                <label class="font-label-caps text-label-caps text-outline mb-1.5 block" for="r_name">ROSTER NAME</label>
                <input id="r_name" type="text"
                       placeholder="e.g. Weekend Shift, Household Chores"
                       class="w-full bg-surface border border-outline-variant rounded-xl px-4 py-3 text-on-surface placeholder:text-outline focus:outline-none focus:border-primary font-body-md min-h-[48px]"
                       @bind="newRosterName" />
            </div>

            <!-- Rotation Logic -->
            <div>
                <label class="font-label-caps text-label-caps text-outline mb-1.5 block" for="r_logic">ROTATION LOGIC</label>
                <select id="r_logic"
                        class="w-full bg-surface border border-outline-variant rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary font-body-md min-h-[48px]"
                        @bind="newRotationType">
                    <option value="@TurnIt.Models.RosterRotationType.Sequential">FIFO Sequential — one by one in order</option>
                    <option value="@TurnIt.Models.RosterRotationType.WeeklyPattern">Weekly Pattern — 7-day cycles</option>
                    <option value="@TurnIt.Models.RosterRotationType.Custom">Custom</option>
                </select>
            </div>

            <!-- Start Date -->
            <div>
                <label class="font-label-caps text-label-caps text-outline mb-1.5 block" for="r_start">START DATE</label>
                <input id="r_start" type="date"
                       class="w-full bg-surface border border-outline-variant rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary font-body-md min-h-[48px]"
                       @bind="newStartDate" />
            </div>

            <!-- Info card -->
            <div class="bg-surface-container-low border border-outline-variant rounded-2xl p-4 flex gap-3">
                <span class="material-symbols-outlined text-primary text-[20px] shrink-0 mt-0.5">info</span>
                <p class="font-body-sm text-on-surface-variant">
                    After creating this roster, head to the <strong class="text-on-surface">Roster tab</strong> to add team members and start the rotation.
                </p>
            </div>
        </div>

        <!-- Footer -->
        <footer class="px-4 py-4 border-t border-outline-variant bg-surface-bright shrink-0 flex flex-col gap-2"
                style="padding-bottom: calc(1rem + env(safe-area-inset-bottom, 0px))">
            <button class="w-full py-4 bg-roster-1 text-white font-label-caps text-label-caps rounded-2xl flex items-center justify-center gap-2 hover:brightness-110 active:scale-[0.98] transition-all min-h-[52px]"
                    @onclick="CreateRoster">
                CREATE ROSTER
                <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
            </button>
            <button class="w-full py-3 border border-outline-variant text-on-surface-variant font-label-caps text-label-caps rounded-2xl hover:bg-surface-variant active:bg-surface-container transition-colors min-h-[48px]"
                    @onclick="Close">
                CANCEL
            </button>
        </footer>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Inject] public TurnFillDataService DataService { get; set; } = default!;
    [Inject] public NavigationManager NavManager { get; set; } = default!;

    private string newRosterName = "";
    private TurnIt.Models.RosterRotationType newRotationType = TurnIt.Models.RosterRotationType.Sequential;
    private DateTime newStartDate = DateTime.Today;

    protected override void OnParametersSet()
    {
        if (IsVisible) { newRosterName = ""; newRotationType = TurnIt.Models.RosterRotationType.Sequential; newStartDate = DateTime.Today; }
    }

    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    private async Task CreateRoster()
    {
        if (!string.IsNullOrWhiteSpace(newRosterName))
        {
            var roster = new TurnIt.Models.Roster(Guid.NewGuid(), DataService.CurrentSpaceId, newRosterName, newRotationType)
            {
                ScheduleStartDate = DateOnly.FromDateTime(newStartDate)
            };
            await DataService.AddRoster(roster);
            await Close();
            NavManager.NavigateTo("/rosters");
        }
    }
}
