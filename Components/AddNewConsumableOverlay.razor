@if (IsVisible)
{
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/60 backdrop-blur-[2px] z-40" @onclick="Close"></div>

    <!-- Full-screen slide-over from right (full width on mobile) -->
    <div class="fixed inset-y-0 right-0 w-full sm:w-[85%] max-w-md bg-surface-bright z-50 flex flex-col slide-over-enter slide-over-active">
        <!-- Header -->
        <header class="flex items-center justify-between px-4 h-14 border-b border-outline-variant bg-surface-bright shrink-0"
                style="padding-top: env(safe-area-inset-top, 0px)">
            <button class="w-11 h-11 flex items-center justify-center rounded-full hover:bg-surface-variant active:bg-surface-container transition-colors"
                    @onclick="Close">
                <span class="material-symbols-outlined text-on-surface">close</span>
            </button>
            <h1 class="font-headline-sm text-headline-sm text-on-surface">New Consumable</h1>
            <div class="w-11"></div><!-- spacer -->
        </header>

        <!-- Form body -->
        <div class="flex-1 overflow-y-auto px-4 py-5 space-y-4">
            <p class="text-on-surface-variant font-body-md">
                Track a physical item that gets depleted and needs refilling.
            </p>

            <!-- Name -->
            <div>
                <label class="font-label-caps text-label-caps text-outline mb-1.5 block" for="c_name">CONSUMABLE NAME</label>
                <input id="c_name" type="text"
                       placeholder="e.g. Printer Ink, Coffee, LPG"
                       class="w-full bg-surface border border-outline-variant rounded-xl px-4 py-3 text-on-surface placeholder:text-outline focus:outline-none focus:border-primary font-body-md min-h-[48px]"
                       @bind="newResource.Name" @bind:event="oninput" />
            </div>

            <!-- Current Level + Duration -->
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="font-label-caps text-label-caps text-outline mb-1.5 block" for="c_level">LEVEL (%)</label>
                    <input id="c_level" type="number" min="0" max="100" placeholder="100"
                           class="w-full bg-surface border border-outline-variant rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary font-body-md min-h-[48px]"
                           @bind="newResource.CurrentLevelPercentage" @bind:event="oninput" />
                </div>
                <div>
                    <label class="font-label-caps text-label-caps text-outline mb-1.5 block" for="c_days">DURATION (DAYS)</label>
                    <input id="c_days" type="number" min="1" placeholder="30"
                           class="w-full bg-surface border border-outline-variant rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary font-body-md min-h-[48px]"
                           @bind="newResource.InitialEstimateDays" @bind:event="oninput" />
                </div>
            </div>

            <!-- Level preview bar -->
            <div class="bg-surface-container rounded-xl p-3 border border-outline-variant">
                <div class="flex items-center justify-between mb-2">
                    <span class="font-label-caps text-label-caps text-outline">PREVIEW</span>
                    <span class="font-data-mono text-data-mono @newResource.StateTextColorClass">@newResource.State.ToString().ToUpper()</span>
                </div>
                <div class="h-3 bg-surface-container-lowest rounded-full overflow-hidden">
                    <div class="h-full @newResource.StateColorClass rounded-full transition-all duration-500"
                         style="width: @(newResource.CurrentLevelPercentage)%"></div>
                </div>
            </div>
        </div>

        <!-- Footer actions -->
        <footer class="px-4 py-4 border-t border-outline-variant bg-surface-bright shrink-0 flex flex-col gap-2"
                style="padding-bottom: calc(1rem + env(safe-area-inset-bottom, 0px))">
            <button class="w-full py-4 bg-primary text-on-primary font-label-caps text-label-caps rounded-2xl flex items-center justify-center gap-2 hover:brightness-110 active:scale-[0.98] transition-all min-h-[52px]"
                    @onclick="CreateResource">
                CREATE CONSUMABLE
                <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
            </button>
            <button class="w-full py-3 border border-outline-variant text-on-surface-variant font-label-caps text-label-caps rounded-2xl hover:bg-surface-variant active:bg-surface-container transition-colors min-h-[48px]"
                    @onclick="Close">
                CANCEL
            </button>
        </footer>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Inject] public TurnFillDataService DataService { get; set; } = default!;

    private Resource newResource = new Resource();

    protected override void OnParametersSet()
    {
        if (IsVisible) newResource = new Resource();
    }

    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    private async Task CreateResource()
    {
        if (!string.IsNullOrWhiteSpace(newResource.Name))
        {
            newResource.Id = newResource.Name.ToLower().Replace(" ", "-");
            await DataService.AddResource(newResource);
            await Close();
        }
    }
}
