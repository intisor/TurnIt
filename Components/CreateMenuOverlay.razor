@if (IsVisible)
{
    <!-- Backdrop -->
    <div class="fixed inset-0 z-50 flex items-end bg-black/60 backdrop-blur-[2px]" @onclick="Close">
        <!-- Bottom Sheet — full width on mobile -->
        <div class="w-full bg-surface-bright rounded-t-2xl overflow-hidden animate-slide-up shadow-2xl border-t border-outline-variant max-h-[90vh] flex flex-col"
             @onclick:stopPropagation="true">

            <!-- Drag handle -->
            <div class="flex justify-center pt-3 pb-1 shrink-0">
                <div class="w-10 h-1 bg-outline-variant rounded-full"></div>
            </div>

            <!-- Header -->
            <div class="px-4 pb-4 pt-1 border-b border-outline-variant shrink-0">
                <span class="font-label-caps text-label-caps text-primary mb-1 block">CREATE NEW</span>
                <h2 class="font-headline-md text-headline-md text-on-surface">What do you want to create?</h2>
            </div>

            <!-- Options — scrollable if needed -->
            <div class="flex flex-col gap-3 px-4 py-4 overflow-y-auto">
                <!-- Consumable option -->
                <button class="w-full min-h-[72px] flex items-center gap-4 bg-surface-container-low border border-outline-variant rounded-2xl px-4 py-4 text-left active:bg-surface-container active:scale-[0.99] transition-all group"
                        @onclick="CreateConsumable">
                    <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center shrink-0 group-active:scale-90 transition-transform">
                        <span class="material-symbols-outlined text-primary text-[28px]" style="font-variation-settings: 'FILL' 1;">inventory_2</span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <span class="font-headline-sm text-on-surface block">Consumable</span>
                        <span class="font-body-sm text-on-surface-variant block">Track a physical item — coffee, ink, gas, etc.</span>
                    </div>
                    <span class="material-symbols-outlined text-outline shrink-0">chevron_right</span>
                </button>

                <!-- Roster option -->
                <button class="w-full min-h-[72px] flex items-center gap-4 bg-surface-container-low border border-outline-variant rounded-2xl px-4 py-4 text-left active:bg-surface-container active:scale-[0.99] transition-all group"
                        @onclick="CreateRoster">
                    <div class="w-14 h-14 rounded-2xl bg-roster-1/10 flex items-center justify-center shrink-0 group-active:scale-90 transition-transform">
                        <span class="material-symbols-outlined text-roster-1 text-[28px]" style="font-variation-settings: 'FILL' 1;">groups</span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <span class="font-headline-sm text-on-surface block">Roster</span>
                        <span class="font-body-sm text-on-surface-variant block">Create a rotation group to share tasks fairly.</span>
                    </div>
                    <span class="material-symbols-outlined text-outline shrink-0">chevron_right</span>
                </button>

                <!-- Cancel -->
                <button class="w-full py-4 mt-1 border border-outline-variant rounded-2xl font-label-caps text-label-caps text-on-surface-variant hover:bg-surface-variant active:bg-surface-container transition-colors min-h-[48px]"
                        @onclick="Close">
                    CANCEL
                </button>
            </div>

            <!-- Safe area spacer -->
            <div style="height: env(safe-area-inset-bottom, 16px)" class="shrink-0"></div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public EventCallback OnCreateConsumable { get; set; }
    [Parameter] public EventCallback OnCreateRoster { get; set; }

    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    private async Task CreateConsumable() { await Close(); await OnCreateConsumable.InvokeAsync(); }
    private async Task CreateRoster()     { await Close(); await OnCreateRoster.InvokeAsync(); }
}
