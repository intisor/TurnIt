@inherits LayoutComponentBase
@inject NavigationManager NavManager
@inject TurnIt.Services.TurnFillDataService DataService
@implements IDisposable

<div class="flex flex-col min-h-dvh bg-background text-on-background font-body-md">
    <!-- TopAppBar — 56px, sticky -->
    <header class="w-full sticky top-0 z-40 flex justify-between items-center px-4 h-14 bg-background border-b border-outline-variant">
        <button aria-label="Team" class="w-11 h-11 flex items-center justify-center rounded-full hover:bg-surface-variant active:bg-surface-container text-primary transition-colors">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size:24px;">groups</span>
        </button>
        <h1 class="font-headline-md text-headline-md font-bold text-primary tracking-tight">TurnFill</h1>
        <button aria-label="Create new" class="w-11 h-11 flex items-center justify-center rounded-full hover:bg-surface-variant active:bg-surface-container text-primary transition-colors" @onclick="ToggleCreateMenu">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size:24px;">add</span>
        </button>
    </header>

    <!-- Main Canvas — edge-to-edge, bottom padded for nav -->
    <main class="flex-1 overflow-y-auto" style="padding-bottom: calc(4rem + env(safe-area-inset-bottom, 0px))">
        @if (isReady)
        {
            @Body
        }
        else
        {
            <div class="flex justify-center items-center h-[60vh]">
                <div class="flex flex-col items-center gap-3">
                    <div class="w-8 h-8 border-2 border-outline-variant border-t-primary rounded-full animate-spin"></div>
                    <span class="font-label-caps text-label-caps text-outline">LOADING</span>
                </div>
            </div>
        }
    </main>

    <!-- Bottom Navigation Bar -->
    <nav class="fixed bottom-0 left-0 right-0 z-50 flex justify-around items-center h-16 bg-surface-container-low border-t border-outline-variant"
         style="padding-bottom: env(safe-area-inset-bottom, 0px);">
        <a href="" id="nav-dashboard" class="@GetNavClass("")">
            <span class="material-symbols-outlined text-[22px] mb-0.5" style="@GetIconStyle("")">dashboard</span>
            <span class="font-label-caps text-[9px] uppercase tracking-widest">Home</span>
        </a>
        <a href="rosters" id="nav-rosters" class="@GetNavClass("rosters")">
            <span class="material-symbols-outlined text-[22px] mb-0.5" style="@GetIconStyle("rosters")">group</span>
            <span class="font-label-caps text-[9px] uppercase tracking-widest">Roster</span>
        </a>
        <a href="schedule" id="nav-schedule" class="@GetNavClass("schedule")">
            <span class="material-symbols-outlined text-[22px] mb-0.5" style="@GetIconStyle("schedule")">calendar_today</span>
            <span class="font-label-caps text-[9px] uppercase tracking-widest">Schedule</span>
        </a>
        <a href="settings" id="nav-settings" class="@GetNavClass("settings")">
            <span class="material-symbols-outlined text-[22px] mb-0.5" style="@GetIconStyle("settings")">settings</span>
            <span class="font-label-caps text-[9px] uppercase tracking-widest">Settings</span>
        </a>
    </nav>

    <!-- Global Overlays -->
    <CreateMenuOverlay @bind-IsVisible="showCreateMenu" OnCreateConsumable="OpenConsumableOverlay" OnCreateRoster="OpenRosterOverlay" />
    <AddNewConsumableOverlay @bind-IsVisible="showAddNewConsumable" />
    <AddNewRosterOverlay @bind-IsVisible="showAddNewRoster" />
</div>

@code {
    private bool showCreateMenu = false;
    private bool showAddNewConsumable = false;
    private bool showAddNewRoster = false;
    private bool isReady = false;

    protected override async Task OnInitializedAsync()
    {
        NavManager.LocationChanged += OnLocationChanged;
        await DataService.InitializeAsync();
        isReady = true;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= OnLocationChanged;
    }

    private void ToggleCreateMenu() => showCreateMenu = true;
    private void OpenConsumableOverlay() => showAddNewConsumable = true;
    private void OpenRosterOverlay() => showAddNewRoster = true;

    private string GetNavClass(string href)
    {
        var relativePath = NavManager.ToBaseRelativePath(NavManager.Uri).TrimEnd('/');
        bool isActive = relativePath.Equals(href, StringComparison.OrdinalIgnoreCase);
        return isActive
            ? "flex flex-col items-center justify-center px-5 py-1 rounded-2xl bg-secondary-container/20 text-primary min-w-[3rem] transition-all"
            : "flex flex-col items-center justify-center px-5 py-1 text-on-surface-variant hover:text-on-surface min-w-[3rem] transition-all";
    }

    private string GetIconStyle(string href)
    {
        var relativePath = NavManager.ToBaseRelativePath(NavManager.Uri).TrimEnd('/');
        bool isActive = relativePath.Equals(href, StringComparison.OrdinalIgnoreCase);
        return isActive ? "font-variation-settings: 'FILL' 1;" : "";
    }
}
