@if (IsVisible && TargetResource != null)
{
    <!-- Overlay / Bottom Sheet Container -->
    <div class="fixed inset-0 z-50 flex items-end justify-center bg-black/60 backdrop-blur-[2px]" @onclick="Close">
        <!-- Bottom Sheet -->
        <div class="w-full max-w-2xl bg-surface-bright rounded-t-xl overflow-hidden animate-slide-up shadow-2xl border-t border-x border-outline-variant" @onclick:stopPropagation="true">
            <!-- Drag Handle Decor -->
            <div class="w-full flex justify-center py-stack-sm">
                <div class="w-12 h-1 bg-outline-variant rounded-full"></div>
            </div>

            <div class="px-margin-page pb-stack-lg pt-stack-sm">
                <!-- Header -->
                <div class="flex items-start justify-between mb-stack-md">
                    <div class="flex flex-col">
                        <span class="font-label-caps text-label-caps text-roster-4 mb-base">ACTION REQUIRED</span>
                        <h2 class="font-headline-md text-headline-md">Confirm Refill for @TargetResource.Name?</h2>
                    </div>
                    <div class="bg-surface-container-highest p-stack-sm rounded-lg border border-outline-variant">
                        <span class="material-symbols-outlined text-roster-4">sync</span>
                    </div>
                </div>

                @if (TargetResource.CurrentAssignee != null)
                {
                    <!-- Highlight Section: Next Person -->
                    <div class="bg-surface-container-low border-2 @TargetResource.CurrentAssignee.ColorClass.Replace("bg-", "border-") p-stack-md rounded-lg mb-stack-lg flex items-center gap-stack-md">
                        <div class="relative">
                            <div class="w-16 h-16 rounded-full border-2 @TargetResource.CurrentAssignee.ColorClass.Replace("bg-", "border-") @TargetResource.CurrentAssignee.ColorClass flex items-center justify-center text-white text-2xl font-bold">
                                @TargetResource.CurrentAssignee.Initials
                            </div>
                            <div class="absolute -bottom-1 -right-1 @TargetResource.CurrentAssignee.ColorClass text-white p-1 rounded-full border-2 border-surface-bright">
                                <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
                            </div>
                        </div>
                        <div class="flex-grow">
                            <span class="font-label-caps text-label-caps @TargetResource.CurrentAssignee.ColorClass.Replace("bg-", "text-")">CURRENT TURN</span>
                            <p class="font-headline-sm text-headline-sm">@TargetResource.CurrentAssignee.Name</p>
                            <p class="text-on-surface-variant font-body-md">Completing this refill will log 1 activity to @(TargetResource.CurrentAssignee.Name)'s history.</p>
                        </div>
                    </div>
                }

                <!-- Refill Details Form -->
                <div class="space-y-stack-sm mb-stack-lg">
                    <div class="grid grid-cols-2 gap-stack-md">
                        <div>
                            <label class="block font-label-caps text-label-caps text-outline mb-1">REFILL DATE</label>
                            <input type="date" class="w-full bg-surface-container-high border border-outline-variant rounded p-2 text-on-surface focus:outline-none focus:border-primary" @bind="refillDate" />
                        </div>
                        <div>
                            <label class="block font-label-caps text-label-caps text-outline mb-1">QUANTITY</label>
                            <input type="number" step="0.1" class="w-full bg-surface-container-high border border-outline-variant rounded p-2 text-on-surface focus:outline-none focus:border-primary" @bind="refillQuantity" />
                        </div>
                    </div>
                    <div>
                        <label class="block font-label-caps text-label-caps text-outline mb-1">COST (OPTIONAL)</label>
                        <input type="number" step="0.01" class="w-full bg-surface-container-high border border-outline-variant rounded p-2 text-on-surface focus:outline-none focus:border-primary" @bind="refillCost" placeholder="0.00" />
                    </div>
                    <div>
                        <label class="block font-label-caps text-label-caps text-outline mb-1">NOTES</label>
                        <textarea class="w-full bg-surface-container-high border border-outline-variant rounded p-2 text-on-surface focus:outline-none focus:border-primary" rows="2" @bind="refillNotes" placeholder="Add any details about this refill..."></textarea>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-stack-md">
                    <button class="w-full py-4 px-stack-md border border-outline font-label-caps text-label-caps text-on-surface-variant hover:bg-surface-variant transition-colors rounded-lg flex items-center justify-center gap-base" @onclick="Close">
                        CANCEL
                    </button>
                    <button class="w-full py-4 px-stack-md bg-roster-4 text-on-tertiary-fixed font-label-caps text-label-caps font-bold hover:brightness-110 active:scale-95 transition-all rounded-lg flex items-center justify-center gap-base" @onclick="Confirm">
                        <span class="material-symbols-outlined text-[20px]">check_circle</span>
                        CONFIRM &amp; LOG
                    </button>
                </div>
            </div>
            <!-- Safe area bottom padding -->
            <div class="h-8"></div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }

    [Parameter]
    public Resource? TargetResource { get; set; }

    [Inject]
    public TurnFillDataService DataService { get; set; } = default!;

    private DateTime refillDate = DateTime.Today;
    private decimal refillQuantity = 1m;
    private decimal? refillCost = null;
    private string refillNotes = "";

    protected override void OnParametersSet()
    {
        if (IsVisible)
        {
            refillDate = DateTime.Today;
            refillQuantity = 1m;
            refillCost = null;
            refillNotes = "";
        }
    }

    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    private async Task Confirm()
    {
        if (TargetResource != null)
        {
            await DataService.RefillResource(TargetResource.Id, refillDate, refillQuantity, refillCost, refillNotes);
            await Close();
        }
    }
}
