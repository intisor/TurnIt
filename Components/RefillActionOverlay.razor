@if (IsVisible && TargetResource != null)
{
    <!-- Backdrop -->
    <div class="fixed inset-0 z-50 flex items-end bg-black/60 backdrop-blur-[2px]" @onclick="Close">
        <!-- Bottom Sheet — full width -->
        <div class="w-full bg-surface-bright rounded-t-2xl overflow-hidden animate-slide-up shadow-2xl border-t border-outline-variant max-h-[90vh] flex flex-col"
             @onclick:stopPropagation="true">

            <!-- Drag handle -->
            <div class="flex justify-center pt-3 pb-1 shrink-0">
                <div class="w-10 h-1 bg-outline-variant rounded-full"></div>
            </div>

            <div class="overflow-y-auto flex-1">
                <div class="px-4 pt-2 pb-4">
                    <!-- Header -->
                    <div class="flex items-start justify-between mb-4">
                        <div>
                            <span class="font-label-caps text-label-caps text-roster-4 mb-1 block">LOG REFILL</span>
                            <h2 class="font-headline-md text-headline-md text-on-surface">@TargetResource.Name</h2>
                        </div>
                        <div class="w-11 h-11 rounded-2xl bg-roster-4/10 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-roster-4 text-[22px]">sync</span>
                        </div>
                    </div>

                    <!-- Assignee block -->
                    @if (TargetResource.CurrentAssignee != null)
                    {
                        <div class="flex items-center gap-3 bg-surface-container rounded-2xl p-3 mb-4 border border-outline-variant">
                            <div class="w-12 h-12 rounded-full @TargetResource.CurrentAssignee.ColorClass flex items-center justify-center text-white text-xl font-bold shrink-0">
                                @TargetResource.CurrentAssignee.Initials
                            </div>
                            <div class="flex-1 min-w-0">
                                <span class="font-label-caps text-label-caps text-outline block mb-0.5">CURRENT TURN</span>
                                <span class="font-headline-sm text-on-surface block">@TargetResource.CurrentAssignee.Name</span>
                                <span class="font-body-sm text-on-surface-variant block">This refill will be logged to their history.</span>
                            </div>
                        </div>
                    }

                    <!-- Form fields -->
                    <div class="space-y-3 mb-5">
                        <!-- Date + Quantity — stacked on mobile, side-by-side on sm -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            <div>
                                <label class="font-label-caps text-label-caps text-outline mb-1.5 block">REFILL DATE</label>
                                <input type="date"
                                       class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary font-body-md min-h-[48px]"
                                       @bind="refillDate" />
                            </div>
                            <div>
                                <label class="font-label-caps text-label-caps text-outline mb-1.5 block">QUANTITY</label>
                                <input type="number" step="0.1"
                                       class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary font-body-md min-h-[48px]"
                                       @bind="refillQuantity" />
                            </div>
                        </div>

                        <div>
                            <label class="font-label-caps text-label-caps text-outline mb-1.5 block">COST <span class="text-outline-variant normal-case">(optional)</span></label>
                            <input type="number" step="0.01" placeholder="0.00"
                                   class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary font-body-md min-h-[48px]"
                                   @bind="refillCost" />
                        </div>

                        <div>
                            <label class="font-label-caps text-label-caps text-outline mb-1.5 block">NOTES <span class="text-outline-variant normal-case">(optional)</span></label>
                            <textarea rows="2" placeholder="Any details about this refill…"
                                      class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary font-body-md resize-none"
                                      @bind="refillNotes"></textarea>
                        </div>
                    </div>

                    <!-- Actions — Confirm on top (primary CTA), Cancel below -->
                    <div class="flex flex-col gap-2">
                        <button class="w-full py-4 bg-roster-4 text-on-tertiary-fixed font-label-caps text-label-caps font-bold rounded-2xl flex items-center justify-center gap-2 active:scale-[0.98] hover:brightness-110 transition-all min-h-[52px]"
                                @onclick="Confirm">
                            <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                            CONFIRM &amp; LOG
                        </button>
                        <button class="w-full py-3 border border-outline-variant font-label-caps text-label-caps text-on-surface-variant rounded-2xl hover:bg-surface-variant active:bg-surface-container transition-colors min-h-[48px]"
                                @onclick="Close">
                            CANCEL
                        </button>
                    </div>
                </div>
            </div>

            <!-- Safe area spacer -->
            <div style="height: env(safe-area-inset-bottom, 16px)" class="shrink-0"></div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public Resource? TargetResource { get; set; }
    [Inject] public TurnFillDataService DataService { get; set; } = default!;

    private DateTime refillDate = DateTime.Today;
    private decimal refillQuantity = 1m;
    private decimal? refillCost = null;
    private string refillNotes = "";

    protected override void OnParametersSet()
    {
        if (IsVisible) { refillDate = DateTime.Today; refillQuantity = 1m; refillCost = null; refillNotes = ""; }
    }

    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    private async Task Confirm()
    {
        if (TargetResource != null)
        {
            await DataService.RefillResource(TargetResource.Id, refillDate, refillQuantity, refillCost, refillNotes);
            await Close();
        }
    }
}
