@page "/"
@inject NavigationManager NavManager
@inject TurnFillDataService DataService
@implements IDisposable

<PageTitle>TurnFill — Dashboard</PageTitle>

<!-- Page Header -->
<div class="flex justify-between items-center px-4 py-3 border-b border-outline-variant">
    <h2 class="font-headline-sm text-headline-sm text-on-surface">Resources</h2>
    <span class="font-label-caps text-label-caps text-outline">@DataService.Resources.Count ITEMS</span>
</div>

@if (!DataService.Resources.Any())
{
    <!-- Empty State -->
    <div class="flex flex-col items-center justify-center px-8 py-16 text-center">
        <span class="material-symbols-outlined text-6xl text-outline mb-4" style="font-variation-settings: 'FILL' 0;">inventory_2</span>
        <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2">No resources yet</h3>
        <p class="text-on-surface-variant font-body-md mb-6">Tap the <strong class="text-primary">+</strong> button to track your first consumable.</p>
    </div>
}
else
{
    <div class="px-4 py-3 space-y-3">
        @foreach (var item in DataService.Resources)
        {
            var buttonClass = item.State == ResourceState.Urgent
                ? $"{item.StateColorClass} text-white border-none py-3 px-5 rounded-xl font-label-caps text-label-caps uppercase tracking-wider active:scale-95 shadow-sm"
                : $"bg-surface-container text-on-surface-variant border border-outline-variant py-3 px-5 rounded-xl font-label-caps text-label-caps uppercase tracking-wider active:scale-95";
            var buttonText = item.State == ResourceState.Urgent ? "Refill!" : "Log Use";

            <article @onclick="@(() => NavigateToDetail(item.Id))"
                     class="relative w-full rounded-2xl overflow-hidden border border-outline-variant bg-surface cursor-pointer active:scale-[0.99] transition-transform">
                <!-- Level fill bar (vertical, behind content) -->
                <div class="absolute bottom-0 left-0 w-full @(item.StateColorClass) opacity-[0.12] fill-bar transition-all duration-700"
                     style="height: @(item.CurrentLevelPercentage)%;"></div>

                <div class="relative z-10 p-4">
                    <!-- Top row: name + state badge -->
                    <div class="flex items-start justify-between mb-3">
                        <h3 class="font-headline-sm text-headline-sm text-on-surface leading-tight pr-2">@item.Name</h3>
                        <span class="font-label-caps text-[9px] uppercase tracking-widest px-2 py-1 rounded-full border shrink-0
                                     @(item.State == ResourceState.Urgent ? "bg-state-urgent/20 text-state-urgent border-state-urgent/40" :
                                       item.State == ResourceState.Depleting ? "bg-state-warning/20 text-state-warning border-state-warning/40" :
                                       "bg-state-healthy/20 text-state-healthy border-state-healthy/40")">
                            @(item.State == ResourceState.Urgent ? "Urgent" : item.State == ResourceState.Depleting ? "Low" : "OK")
                        </span>
                    </div>

                    <!-- Middle: big percentage + assignee -->
                    <div class="flex items-end justify-between">
                        <div>
                            <span class="font-display-lg text-display-lg text-on-surface leading-none">@item.CurrentLevelPercentage<span class="text-2xl text-on-surface-variant font-normal">%</span></span>
                            @if (item.Forecast != null)
                            {
                                <p class="font-label-caps text-label-caps text-outline mt-1">~@((int)item.Forecast.AverageDurationDays) DAYS AVG</p>
                            }
                        </div>

                        <!-- Assignee + Action -->
                        <div class="flex flex-col items-end gap-2">
                            @if (item.CurrentAssignee != null)
                            {
                                <div class="flex items-center gap-1.5">
                                    <span class="font-label-caps text-[9px] text-outline uppercase">Turn:</span>
                                    <div class="w-7 h-7 rounded-full @item.CurrentAssignee.ColorClass flex items-center justify-center text-white text-[11px] font-bold">
                                        @item.CurrentAssignee.Initials
                                    </div>
                                </div>
                            }
                            <button @onclick="() => PromptRefill(item)"
                                    @onclick:stopPropagation="true"
                                    class="@buttonClass min-h-[44px]">
                                @buttonText
                            </button>
                        </div>
                    </div>
                </div>
            </article>
        }
    </div>
}

<RefillActionOverlay @bind-IsVisible="showRefillPrompt" TargetResource="selectedResource" />

@code {
    private bool showRefillPrompt = false;
    private Resource? selectedResource;

    protected override void OnInitialized()
    {
        DataService.OnStateChanged += StateHasChanged;
    }

    public void Dispose()
    {
        DataService.OnStateChanged -= StateHasChanged;
    }

    private void NavigateToDetail(string id)
    {
        NavManager.NavigateTo($"/resource/{id}");
    }

    private void PromptRefill(Resource item)
    {
        selectedResource = item;
        showRefillPrompt = true;
    }
}
