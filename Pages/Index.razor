@page "/"
@inject NavigationManager NavManager
@inject TurnFillDataService DataService
@implements IDisposable

<PageTitle>TurnFill - Dashboard</PageTitle>

<!-- Header Text -->
<div class="pb-stack-sm pt-stack-sm flex justify-between items-end border-b border-outline-variant">
    <h2 class="font-headline-md text-headline-md text-on-surface">Resource Status</h2>
    <span class="font-data-mono text-data-mono text-on-surface-variant">@DataService.Resources.Count Items</span>
</div>

@foreach (var item in DataService.Resources)
{
    var borderHoverClass = "group-hover:" + item.StateBorderColorClass;
    var buttonClass = item.State == ResourceState.Urgent 
        ? $"{item.StateColorClass} text-white border-none px-6 py-2 rounded-lg font-label-caps text-label-caps uppercase tracking-wider transition-colors hover:brightness-110 active:scale-95 shadow-none"
        : $"bg-surface-variant text-on-surface-variant hover:{item.StateColorClass} hover:text-white border border-outline-variant hover:{item.StateBorderColorClass} px-4 py-2 rounded-lg font-label-caps text-label-caps uppercase tracking-wider transition-colors";
    
    var buttonText = item.State == ResourceState.Urgent ? "Refill" : "Log Use";

    <article @onclick="@(() => NavigateToDetail(item.Id))" class="relative w-full h-48 bg-surface rounded-xl overflow-hidden border border-outline-variant cursor-pointer group mb-stack-md">
        <!-- Vertical Fill Indicator -->
        <div class="absolute bottom-0 left-0 w-full @(item.StateColorClass) opacity-20 fill-bar" style="height: @(item.CurrentLevelPercentage)%;"></div>
        
        <div class="relative z-10 w-full h-full flex flex-col justify-between p-stack-md">
            <div class="flex justify-between items-start w-full">
                <h3 class="font-headline-md text-headline-md text-on-surface">@item.Name</h3>
                
                @* Roster chip removed for now *@
            </div>
            
            <div class="flex justify-between items-end w-full">
                <div class="flex flex-col">
                    <span class="font-label-caps text-label-caps @(item.StateTextColorClass) uppercase tracking-wider mb-1">
                        @(item.State == ResourceState.Urgent ? "Urgent" : item.State == ResourceState.Depleting ? "Depleting" : "Healthy")
                    </span>
                    <span class="font-display-lg text-display-lg text-on-surface leading-none">@item.CurrentLevelPercentage%</span>
                </div>
                
                <button @onclick="() => PromptRefill(item)" @onclick:stopPropagation="true" class="@buttonClass">
                    @buttonText
                </button>
            </div>
        </div>
        
        <!-- Active focus border simulation -->
        <div class="absolute inset-0 border-2 border-transparent @borderHoverClass rounded-xl pointer-events-none transition-colors"></div>
    </article>
}

<RefillActionOverlay @bind-IsVisible="showRefillPrompt" TargetResource="selectedResource" />

@code {
    private bool showRefillPrompt = false;
    private Resource? selectedResource;

    protected override void OnInitialized()
    {
        DataService.OnStateChanged += StateHasChanged;
    }

    public void Dispose()
    {
        DataService.OnStateChanged -= StateHasChanged;
    }

    private void NavigateToDetail(string id)
    {
        NavManager.NavigateTo($"/resource/{id}");
    }

    private void PromptRefill(Resource item)
    {
        selectedResource = item;
        showRefillPrompt = true;
    }
}
