@page "/resource/{id?}"
@inject NavigationManager NavManager
@inject TurnFillDataService DataService
@implements IDisposable

<PageTitle>TurnFill - Resource Detail</PageTitle>

<!-- Action Bar (Specific to Detail Page) -->
<div class="flex items-center justify-between pb-stack-sm mb-stack-md border-b border-outline-variant">
    <a href="/" class="flex items-center text-primary hover:text-primary-fixed transition-colors">
        <span class="material-symbols-outlined mr-2">arrow_back</span>
        <span class="font-label-caps uppercase tracking-wider">Back to Dashboard</span>
    </a>
    <div class="flex gap-2">
        <button class="p-2 hover:bg-surface-variant rounded-full text-on-surface-variant transition-colors" title="Sync">
            <span class="material-symbols-outlined">sync_alt</span>
        </button>
        <button class="p-2 hover:bg-surface-variant rounded-full text-on-surface-variant transition-colors" title="More">
            <span class="material-symbols-outlined">more_vert</span>
        </button>
    </div>
</div>

@if (resource == null)
{
    <div class="text-center py-20">
        <h2 class="text-2xl">Resource not found.</h2>
    </div>
}
else
{
    <div class="flex flex-col gap-stack-lg max-w-5xl mx-auto">
        <!-- Large Resource Header -->
        <section class="status-header-bg border-2 border-primary-container p-stack-lg rounded-xl flex flex-col md:flex-row md:items-end justify-between gap-stack-md">
            <div class="space-y-base">
                <span class="font-label-caps text-label-caps text-primary-fixed uppercase tracking-widest">Resource Focus</span>
                <h2 class="font-display-lg text-display-lg text-white">@resource.Name</h2>
                <div class="flex items-center gap-stack-sm @resource.StateTextColorClass">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                    <span class="font-headline-sm text-headline-sm">@resource.CurrentLevelPercentage% @resource.State</span>
                </div>
            </div>
            <div class="flex flex-col items-start md:items-end gap-stack-sm">
                <span class="font-label-caps text-label-caps text-on-surface-variant">Last Refilled: Just now</span>
                <button @onclick="PromptRefill" class="bg-primary-container text-on-primary-container font-label-caps text-label-caps px-stack-lg py-stack-sm font-bold rounded-lg border-2 border-transparent active:scale-95 transition-transform hover:brightness-110">
                    REFILL NOW
                </button>
            </div>
        </section>

        <!-- Bento Grid Layout -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-stack-lg">
            <!-- Usage Analytics (Depletion Line Chart) -->
            <div class="md:col-span-7 bg-surface p-stack-lg border border-outline-variant rounded-xl">
                <div class="flex justify-between items-center mb-stack-lg">
                    <h3 class="font-headline-sm text-headline-sm">Depletion Analysis</h3>
                    <span class="font-label-caps text-label-caps text-on-surface-variant">Last 7 Days</span>
                </div>
                <div class="h-48 w-full relative">
                    <svg class="w-full h-full overflow-visible" viewbox="0 0 700 200">
                        <line stroke="#424754" stroke-width="1" x1="0" x2="700" y1="0" y2="0"></line>
                        <line stroke="#424754" stroke-width="1" x1="0" x2="700" y1="100" y2="100"></line>
                        <line stroke="#424754" stroke-width="2" x1="0" x2="700" y1="200" y2="200"></line>
                        
                        <!-- Dynamic path based on current level -->
                        <path class="flat-chart-line" d="M0,20 L700,@((200 - (resource.CurrentLevelPercentage * 2)))" fill="none" stroke="#4d8eff" stroke-width="4"></path>
                        
                        <circle cx="0" cy="20" fill="#adc6ff" r="4"></circle>
                        <circle cx="700" cy="@((200 - (resource.CurrentLevelPercentage * 2)))" fill="#DC2626" r="4"></circle>
                    </svg>
                    <div class="flex justify-between mt-stack-sm font-data-mono text-data-mono text-on-surface-variant">
                        <span>Mon</span>
                        <span>Tue</span>
                        <span>Wed</span>
                        <span>Thu</span>
                        <span>Fri</span>
                        <span>Sat</span>
                        <span>Sun</span>
                    </div>
                </div>
            </div>

            <!-- Roster Engine -->
            <div class="md:col-span-5 bg-surface p-stack-lg border border-outline-variant rounded-xl">
                <h3 class="font-headline-sm text-headline-sm mb-stack-lg">Roster Engine</h3>
                <div class="relative space-y-stack-lg before:absolute before:left-[15px] before:top-2 before:bottom-2 before:w-[2px] before:bg-outline-variant">
                    
                    @if (DataService.Members.Any())
                    {
                        var members = DataService.Members;
                        var currentIndex = members.IndexOf(resource.CurrentAssignee ?? members.First());
                        if (currentIndex == -1) currentIndex = 0;

                        <!-- Current User -->
                        <div class="relative pl-12">
                            <div class="absolute left-0 top-1 w-8 h-8 rounded-full @members[currentIndex].ColorClass border-2 border-white flex items-center justify-center z-10">
                                <span class="text-[14px] text-white font-bold">@members[currentIndex].Initials</span>
                            </div>
                            <div class="flex flex-col gap-base">
                                <div class="flex justify-between items-start">
                                    <div>
                                        <h4 class="font-headline-sm text-headline-sm @members[currentIndex].ColorClass.Replace("bg-", "text-")">@members[currentIndex].Name</h4>
                                        <span class="font-label-caps text-label-caps text-on-surface-variant">Current Turn</span>
                                    </div>
                                </div>
                                <div class="bg-surface-container-highest px-stack-sm py-base inline-block rounded w-max">
                                    <span class="font-data-mono text-data-mono text-primary">Due: @(resource.State == ResourceState.Urgent ? "Refill Needed" : "Monitoring")</span>
                                </div>
                            </div>
                        </div>

                        <!-- Next Users -->
                        @for (int i = 1; i <= 2; i++)
                        {
                            var nextIdx = (currentIndex + i) % members.Count;
                            var member = members[nextIdx];
                            var opacity = i == 1 ? "opacity-80" : "opacity-60";
                            var label = i == 1 ? "Next" : "Following";

                            <div class="relative pl-12 @opacity">
                                <div class="absolute left-0 top-1 w-8 h-8 rounded-full @member.ColorClass border-2 border-outline flex items-center justify-center z-10">
                                    <span class="text-[14px] text-white font-bold">@member.Initials</span>
                                </div>
                                <div class="flex flex-col gap-base">
                                    <div class="flex justify-between items-start">
                                        <div>
                                            <h4 class="font-headline-sm text-headline-sm @member.ColorClass.Replace("bg-", "text-")">@member.Name</h4>
                                            <span class="font-label-caps text-label-caps text-on-surface-variant">@label</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
                <button class="w-full mt-stack-lg py-stack-md border-2 border-dashed border-outline-variant rounded-lg hover:border-primary-container hover:bg-surface-container transition-all flex items-center justify-center gap-stack-sm">
                    <span class="material-symbols-outlined">person_add</span>
                    <span class="font-label-caps text-label-caps">Add Participant</span>
                </button>
            </div>
        </div>
    </div>
}

<RefillActionOverlay @bind-IsVisible="showRefillPrompt" TargetResource="resource" />

@code {
    [Parameter]
    public string? id { get; set; }

    private Resource? resource;
    private bool showRefillPrompt = false;

    protected override void OnInitialized()
    {
        DataService.OnStateChanged += StateHasChanged;
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(id))
        {
            resource = DataService.Resources.FirstOrDefault(r => r.Id == id);
        }
    }

    public void Dispose()
    {
        DataService.OnStateChanged -= StateHasChanged;
    }

    private void PromptRefill()
    {
        showRefillPrompt = true;
    }
}
