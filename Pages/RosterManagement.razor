@page "/rosters"
@inject TurnFillDataService DataService
@implements IDisposable

<PageTitle>TurnFill — Roster</PageTitle>

<div class="flex flex-col">
    <!-- Page Header -->
    <div class="flex items-center justify-between px-4 py-3 border-b border-outline-variant">
        <h2 class="font-headline-sm text-headline-sm text-on-surface">Roster</h2>
        @if (DataService.ActiveRoster != null)
        {
            <span class="font-label-caps text-label-caps text-outline">@DataService.Members.Count MEMBERS</span>
        }
    </div>

    <!-- Roster Selector -->
    @if (DataService.Rosters.Count > 1)
    {
        <div class="px-4 py-3 border-b border-outline-variant bg-surface-container-low">
            <label class="font-label-caps text-label-caps text-outline mb-1.5 block">ACTIVE ROSTER</label>
            <select class="w-full bg-surface border border-outline-variant rounded-xl px-4 py-3 text-on-surface font-headline-sm focus:outline-none focus:border-primary min-h-[48px]"
                    value="@(DataService.ActiveRoster?.Id.ToString())"
                    @onchange="ChangeRoster">
                @foreach (var roster in DataService.Rosters)
                {
                    <option value="@roster.Id">@roster.Name</option>
                }
            </select>
        </div>
    }
    else if (DataService.ActiveRoster != null)
    {
        <div class="px-4 py-3 bg-surface-container-low border-b border-outline-variant flex items-center gap-2">
            <span class="material-symbols-outlined text-outline text-[18px]">group</span>
            <span class="font-headline-sm text-on-surface">@DataService.ActiveRoster.Name</span>
        </div>
    }

    <!-- Current Rotation Flow -->
    @if (DataService.Members.Any())
    {
        <div class="px-4 pt-4 pb-2">
            <span class="font-label-caps text-label-caps text-outline mb-3 block">ROTATION ORDER</span>
            <div class="flex items-center gap-2 overflow-x-auto no-scrollbar pb-2">
                @for (int i = 0; i < DataService.Members.Count; i++)
                {
                    var member = DataService.Members[i];
                    var isFirst = i == 0;
                    <div class="flex items-center gap-2 shrink-0">
                        <div class="flex flex-col items-center gap-1">
                            <div class="w-11 h-11 rounded-full @member.ColorClass flex items-center justify-center text-white font-bold text-sm @(isFirst ? "ring-2 ring-state-healthy ring-offset-2 ring-offset-background" : "")">
                                @member.Initials
                            </div>
                            @if (isFirst)
                            {
                                <span class="font-label-caps text-[8px] text-state-healthy uppercase tracking-wide">On deck</span>
                            }
                        </div>
                        @if (i < DataService.Members.Count - 1)
                        {
                            <span class="material-symbols-outlined text-outline-variant text-[16px]">chevron_right</span>
                        }
                    </div>
                }
            </div>
        </div>
    }

    <!-- Member List -->
    <div class="px-4 pt-2 pb-2 space-y-2">
        <span class="font-label-caps text-label-caps text-outline">MANAGE MEMBERS</span>

        @for (int i = 0; i < DataService.Members.Count; i++)
        {
            var member = DataService.Members[i];
            var isCurrent = i == 0;
            <div class="flex items-center gap-3 bg-surface border border-outline-variant rounded-2xl p-3 active:bg-surface-container transition-colors">
                <!-- Avatar -->
                <div class="w-11 h-11 rounded-full @member.ColorClass flex items-center justify-center text-white font-bold text-sm shrink-0">
                    @member.Initials
                </div>
                <!-- Name + badge -->
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                        <span class="font-headline-sm text-on-surface truncate">@member.Name</span>
                        @if (isCurrent)
                        {
                            <span class="font-label-caps text-[9px] px-2 py-0.5 rounded-full bg-state-healthy text-white shrink-0">ON DECK</span>
                        }
                    </div>
                    <span class="font-body-sm text-on-surface-variant">Position @(i + 1)</span>
                </div>
                <!-- Actions -->
                <div class="flex items-center gap-1 shrink-0">
                    <button class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container active:bg-surface-container-high text-on-surface-variant transition-colors"
                            title="Skip turn"
                            @onclick="() => SkipMember(member)">
                        <span class="material-symbols-outlined text-[18px]">skip_next</span>
                    </button>
                    <button class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-error-container/20 active:bg-error-container/40 text-error transition-colors"
                            title="Remove"
                            @onclick="() => RemoveMember(member)">
                        <span class="material-symbols-outlined text-[18px]">person_remove</span>
                    </button>
                </div>
            </div>
        }

        <!-- Add Member Form -->
        <div class="flex flex-col gap-2 pt-2">
            <input @bind="newMemberName"
                   @bind:event="oninput"
                   @onkeyup="HandleAddKeyUp"
                   placeholder="Add a team member name…"
                   class="w-full bg-surface border border-outline-variant rounded-xl px-4 py-3 text-on-surface placeholder:text-outline focus:outline-none focus:border-primary font-body-md min-h-[48px]" />
            <button @onclick="AddMember"
                    disabled="@(string.IsNullOrWhiteSpace(newMemberName))"
                    class="w-full py-3 bg-primary text-on-primary font-label-caps text-label-caps rounded-xl hover:brightness-110 active:scale-95 disabled:opacity-40 disabled:pointer-events-none transition-all min-h-[48px]">
                ADD MEMBER
            </button>
        </div>
    </div>

    <!-- Roster Settings -->
    <div class="mx-4 my-4 bg-surface-container rounded-2xl border border-outline-variant overflow-hidden">
        <div class="px-4 py-3 border-b border-outline-variant">
            <span class="font-label-caps text-label-caps text-outline">ROSTER SETTINGS</span>
        </div>

        <!-- Rotation Logic -->
        <div class="px-4 py-3 border-b border-outline-variant">
            <label class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">ROTATION LOGIC</label>
            <select class="w-full bg-surface border border-outline-variant rounded-xl px-4 py-3 text-on-surface font-body-md focus:outline-none focus:border-primary min-h-[48px]"
                    @bind="selectedRotationType">
                <option value="@TurnIt.Models.RosterRotationType.Sequential">FIFO Sequential</option>
                <option value="@TurnIt.Models.RosterRotationType.WeeklyPattern">Weekly Pattern</option>
                <option value="@TurnIt.Models.RosterRotationType.Custom">Custom</option>
            </select>
        </div>

        <!-- Start Date -->
        <div class="px-4 py-3 border-b border-outline-variant">
            <label class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">SCHEDULE START DATE</label>
            <input type="date"
                   class="w-full bg-surface border border-outline-variant rounded-xl px-4 py-3 text-on-surface font-body-md focus:outline-none focus:border-primary min-h-[48px]"
                   @bind="selectedStartDate" />
        </div>

        <!-- Auto-skip toggle -->
        <label class="flex items-center justify-between px-4 py-3 border-b border-outline-variant cursor-pointer">
            <div>
                <span class="font-body-md text-on-surface block">Auto-skip if away</span>
                <span class="font-body-sm text-on-surface-variant">Skip member automatically when marked unavailable</span>
            </div>
            <div class="relative ml-4 shrink-0">
                <input type="checkbox" checked class="sr-only peer" />
                <div class="w-11 h-6 rounded-full bg-primary/30 peer-checked:bg-primary transition-colors"></div>
                <div class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-surface-bright shadow peer-checked:translate-x-5 transition-transform"></div>
            </div>
        </label>

        <!-- Apply button -->
        <div class="px-4 py-3">
            <button @onclick="UpdateConfig"
                    class="w-full py-3 bg-primary-container text-on-primary-container font-label-caps text-label-caps rounded-xl hover:brightness-110 active:scale-95 transition-all min-h-[48px]">
                APPLY SETTINGS
            </button>
        </div>
    </div>
</div>

@code {
    private string newMemberName = "";
    private TurnIt.Models.RosterRotationType selectedRotationType = TurnIt.Models.RosterRotationType.Sequential;
    private DateTime selectedStartDate = DateTime.Today;

    protected override void OnInitialized()
    {
        DataService.OnStateChanged += HandleStateChanged;
        UpdateLocalState();
    }

    private void HandleStateChanged()
    {
        UpdateLocalState();
        StateHasChanged();
    }

    private void UpdateLocalState()
    {
        if (DataService.ActiveRoster != null)
        {
            selectedRotationType = DataService.ActiveRoster.RotationType;
            selectedStartDate = DataService.ActiveRoster.ScheduleStartDate.ToDateTime(TimeOnly.MinValue);
        }
    }

    public void Dispose()
    {
        DataService.OnStateChanged -= HandleStateChanged;
    }

    private async Task ChangeRoster(ChangeEventArgs e)
    {
        if (e.Value != null && Guid.TryParse(e.Value.ToString(), out var rosterId))
            await DataService.SetActiveRoster(rosterId);
    }

    private async Task HandleAddKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddMember();
    }

    private async Task SkipMember(RosterParticipant member)
        => await DataService.SkipMember(member.Id);

    private async Task RemoveMember(RosterParticipant member)
        => await DataService.RemoveMember(member.Id);

    private async Task AddMember()
    {
        if (!string.IsNullOrWhiteSpace(newMemberName))
        {
            await DataService.AddMember(newMemberName);
            newMemberName = "";
        }
    }

    private async Task UpdateConfig()
        => await DataService.UpdateRosterConfig(selectedRotationType, selectedStartDate);
}
