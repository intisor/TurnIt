@page "/rosters"
@using TurnIt.Models
@using TurnIt.Algorithms
@using TurnIt.Services
@inject StorageService Storage
@inject NavigationManager Navigation

<PageTitle>Rosters</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Rosters</h2>
        <button class="btn btn-success" @onclick="ShowAddForm">+ Create Roster</button>
    </div>

    @if (showForm)
    {
        <div class="card mb-4 border-success">
            <div class="card-body">
                <h5 class="card-title">New Roster</h5>
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input type="text" class="form-control" @bind="newRosterName" placeholder="e.g., Cleaning Duty, Cooking" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Description (optional)</label>
                    <textarea class="form-control" @bind="newRosterDescription" rows="2" placeholder="What is this roster for?"></textarea>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Rotation Type</label>
                        <select class="form-select" @bind="newRosterType">
                            <option value="@RosterRotationType.Sequential">Sequential (A→B→C→A...)</option>
                            <option value="@RosterRotationType.WeeklyPattern" disabled>Weekly Pattern (Coming soon)</option>
                            <option value="@RosterRotationType.Custom" disabled>Custom (Coming soon)</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Start Date</label>
                        <input type="date" class="form-control" @bind="newRosterStartDate" />
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-primary" @onclick="AddRoster">Create Roster</button>
                    <button class="btn btn-secondary" @onclick="CancelAddForm">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (rosters.Any())
    {
        <div class="row">
            @foreach (var roster in rosters)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@roster.Name</h5>
                            <p class="text-muted">
                                <small>@roster.RotationType • Starting @roster.ScheduleStartDate</small>
                            </p>
                            @if (!string.IsNullOrEmpty(roster.Description))
                            {
                                <p class="card-text">@roster.Description</p>
                            }

                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-primary" @onclick="() => ViewRoster(roster.Id)">View Schedule</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteRoster(roster.Id)">Delete</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <p>No rosters yet. Click <strong>+ Create Roster</strong> to get started!</p>
        </div>
    }
</div>

@code {
    private List<Roster> rosters = new();
    private bool showForm = false;

    // Add form fields
    private string newRosterName = "";
    private string newRosterDescription = "";
    private RosterRotationType newRosterType = RosterRotationType.Sequential;
    private string newRosterStartDate = DateTime.Today.ToString("yyyy-MM-dd");

    private Guid _currentSpaceId = Guid.NewGuid(); // In real app, get from auth

    protected override async Task OnInitializedAsync()
    {
        await LoadRosters();
    }

    private async Task LoadRosters()
    {
        rosters = await Storage.GetRostersAsync(_currentSpaceId);
        StateHasChanged();
    }

    private void ShowAddForm()
    {
        showForm = true;
    }

    private void CancelAddForm()
    {
        showForm = false;
        newRosterName = "";
        newRosterDescription = "";
        newRosterType = RosterRotationType.Sequential;
        newRosterStartDate = DateTime.Today.ToString("yyyy-MM-dd");
    }

    private async Task AddRoster()
    {
        if (string.IsNullOrWhiteSpace(newRosterName))
        {
            return;
        }

        if (!DateOnly.TryParse(newRosterStartDate, out var startDate))
        {
            return;
        }

        var roster = new Roster(
            Guid.NewGuid(),
            _currentSpaceId,
            newRosterName,
            newRosterType)
        {
            Description = newRosterDescription,
            ScheduleStartDate = startDate,
            CreatedAt = DateTime.UtcNow
        };

        await Storage.SaveRosterAsync(roster);
        await LoadRosters();
        CancelAddForm();
    }

    private void ViewRoster(Guid id)
    {
        Navigation.NavigateTo($"/rosters/{id}");
    }

    private async Task DeleteRoster(Guid id)
    {
        await Storage.DeleteRosterAsync(id);
        await LoadRosters();
    }
}
